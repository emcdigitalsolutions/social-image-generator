<%- include('layout', { title, user }) %>

<div class="breadcrumb">
  <a href="/dashboard">Clienti</a> / <a href="/dashboard/clients/<%= client.id %>"><%= client.display_name %></a> / Piano Editoriale
</div>

<div class="page-header">
  <div>
    <h1><%= plan.title || 'Piano Editoriale' %></h1>
    <span class="badge badge-<%= plan.status %>"><%= plan.status %></span>
  </div>
  <div style="display:flex;gap:8px">
    <% if (plan.status === 'draft') { %>
      <button class="btn btn-primary" onclick="confirmPlan()">Conferma Piano</button>
    <% } %>
  </div>
</div>

<% if (plan.plan_data && plan.plan_data.categories) { %>
<div class="card" style="margin-bottom:24px">
  <div class="card-header"><h3>Categorie</h3></div>
  <table>
    <thead><tr><th>Codice</th><th>Nome</th><th>Frequenza</th><th>Descrizione</th></tr></thead>
    <tbody>
      <% plan.plan_data.categories.forEach(cat => { %>
      <tr>
        <td><strong><%= cat.code %></strong></td>
        <td><%= cat.name %></td>
        <td><%= cat.frequency || '' %></td>
        <td style="font-size:13px;color:var(--gray-500)"><%= cat.description || '' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<h3 style="margin-bottom:16px">Mesi</h3>
<div class="month-buttons">
  <% const totalMonths = (plan.plan_data && plan.plan_data.months) ? plan.plan_data.months.length : 5; %>
  <% for (let m = 1; m <= totalMonths; m++) { %>
    <a href="/dashboard/clients/<%= client.id %>/plan/<%= plan.id %>/month/<%= m %>" class="month-btn">Mese <%= m %></a>
  <% } %>
</div>

<% if (plan.ai_raw && !plan.plan_data) { %>
<div class="card">
  <div class="card-header"><h3>Output AI (raw)</h3></div>
  <pre style="white-space:pre-wrap;font-size:13px;max-height:500px;overflow-y:auto;background:var(--gray-50);padding:16px;border-radius:6px"><%= plan.ai_raw %></pre>
</div>
<% } %>

<script>
  const PLAN_ID = '<%= plan.id %>';
  const CLIENT_ID = '<%= client.id %>';

  async function confirmPlan() {
    if (!confirm('Confermare questo piano editoriale?')) return;
    await apiFetch('/dashboard/api/plans/' + PLAN_ID + '/confirm', { method: 'POST' });
    window.location.reload();
  }
</script>

<%- include('layout-end') %>
