  // Scan website
  async function scanWebsite() {
    const btn = document.getElementById('scan-website-btn');
    const url = document.querySelector('input[name="website"]').value.trim();
    if (!url) { alert('Inserisci un URL nel campo Sito web'); return; }

    btn.disabled = true;
    btn.innerHTML = '<span class="loading"></span> Scansione...';

    try {
      const res = await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/scan-website', {
        method: 'POST',
        body: { url }
      });

      if (res.error) { alert('Errore: ' + res.error); return; }
      if (!res.data) { alert('Nessun dato estratto'); return; }

      const d = res.data;
      const form = document.getElementById('profile-form');
      let filled = 0;

      const fieldMap = {
        display_name: d.display_name,
        brand_name: d.brand_name,
        sector: d.sector,
        location: d.location,
        tagline: d.tagline
      };

      for (const [name, value] of Object.entries(fieldMap)) {
        if (!value) continue;
        const input = form.querySelector('[name="' + name + '"]');
        if (!input) continue;
        // Only fill if field is empty
        if (input.value && input.value.trim()) continue;
        input.value = value;
        input.style.outline = '2px solid #3b82f6';
        input.style.outlineOffset = '-1px';
        filled++;
      }

      // Auto-fill brand color pickers
      if (d.colors && d.colors.length) {
        setBrandColors(d.colors);
      }

      // Show extra info as alert
      let msg = 'Scansione completata: ' + filled + ' campi compilati.';
      if (d.description) msg += '\n\nDescrizione: ' + d.description;
      if (d.services) msg += '\nServizi: ' + d.services;
      if (d.colors && d.colors.length) msg += '\nColori brand: ' + d.colors.join(', ');
      if (d.logo_urls && d.logo_urls.length) msg += '\nLogo trovato nel sito';
      msg += '\n\nRivedi i campi evidenziati e clicca "Salva Profilo".';
      alert(msg);

      // Import logo from website
      if (d.logo_urls && d.logo_urls.length) {
        if (confirm('Logo trovato nel sito. Vuoi importarlo?')) {
          try {
            const logoRes = await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/import-logo', {
              method: 'POST',
              body: { url: d.logo_urls[0] }
            });
            if (logoRes.imported) {
              document.getElementById('logo-status-text').textContent = 'Logo: logo-' + CLIENT_ID + '.svg';
              loadLogoPreview();
              alert('Logo importato dal sito');
            } else if (logoRes.error) {
              alert('Errore importazione logo: ' + logoRes.error);
            }
          } catch (err) {
            alert('Errore importazione logo: ' + err.message);
          }
        }
      }

      // Auto-generate theme from scanned colors
      if (d.colors && d.colors.length >= 2) {
        if (confirm('Vuoi generare automaticamente il tema CSS dai colori del sito?')) {
          generateTheme();
        }
      }
    } catch (err) {
      alert('Errore: ' + (err.message || 'Scansione fallita'));
    } finally {
      btn.disabled = false;
      btn.textContent = 'Scansiona Sito';
    }
  }

  // Generate system instruction
  async function generateSystemInstruction() {
    const btn = document.getElementById('generate-si-btn');
    const textarea = document.getElementById('system-instruction-textarea');

    // Ask confirmation if textarea already has content
    if (textarea.value.trim() && !confirm('Il campo System Instruction contiene già del testo. Vuoi sovrascriverlo con una nuova versione generata dall\'AI?')) {
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="loading"></span> Generazione in corso...';

    try {
      const res = await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/generate-system-instruction', {
        method: 'POST',
        body: {}
      });

      if (res.error) { alert('Errore: ' + res.error); return; }
      if (!res.system_instruction) { alert('Nessun risultato generato'); return; }

      textarea.value = res.system_instruction;
      textarea.style.outline = '2px solid #3b82f6';
      textarea.style.outlineOffset = '-1px';
      alert('System Instruction generato. Rivedi il testo e clicca "Salva AI Config" per salvare.');
    } catch (err) {
      alert('Errore: ' + (err.message || 'Generazione fallita'));
    } finally {
      btn.disabled = false;
      btn.textContent = 'Genera con AI';
    }
  }

  // Load posts
  (async function loadPosts() {
    const plans = await apiFetch('/dashboard/api/plans/by-client/' + CLIENT_ID);
    if (!plans.length) return;
    let allPosts = [];
    for (const plan of plans) {
      for (let m = 1; m <= 5; m++) {
        const posts = await apiFetch('/dashboard/api/posts/by-plan/' + plan.id + '/month/' + m);
        allPosts = allPosts.concat(posts);
      }
    }
    if (allPosts.length) {
      const container = document.getElementById('posts-container');
      container.innerHTML = '<div class="posts-grid">' + allPosts.map(p => `
        <a href="/dashboard/posts/${p.id}" class="post-card" style="text-decoration:none;color:inherit">
          <div class="post-card-image">${p.image_url ? '<img src="' + p.image_url + '">' : 'Nessuna immagine'}</div>
          <div class="post-card-body">
            <h4>${p.category || 'Post'}</h4>
            <p>${p.caption ? p.caption.substring(0, 80) + '...' : p.sub_topic || 'Nessuna caption'}</p>
            <div class="post-card-footer">
              <span class="badge badge-${p.status}">${p.status}</span>
              <span style="font-size:12px;color:var(--gray-400)">M${p.month_number} W${p.week_number}</span>
            </div>
          </div>
        </a>
      `).join('') + '</div>';
    }
  })();
</script>

