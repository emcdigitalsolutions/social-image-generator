<%- include('layout', { title, user }) %>

<div class="breadcrumb">
  <a href="/dashboard">Clienti</a> / <%= client.display_name %>
</div>

<div class="page-header">
  <h1><%= client.display_name %></h1>
  <span class="badge badge-<%= client.status %>"><%= client.status %></span>
</div>

<div class="tabs">
  <button class="tab active" data-tab="profilo">Profilo</button>
  <button class="tab" data-tab="questionario">Questionario</button>
  <button class="tab" data-tab="piano">Piano Editoriale</button>
  <button class="tab" data-tab="posts">Post</button>
  <button class="tab" data-tab="impostazioni">Impostazioni</button>
</div>

<!-- Tab: Profilo -->
<div class="tab-content active" id="tab-profilo">
  <div class="card">
    <div class="card-header"><h3>Informazioni Brand</h3></div>
    <form id="profile-form">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="form-group">
          <label>Nome visualizzato</label>
          <input type="text" name="display_name" value="<%= client.display_name || '' %>">
        </div>
        <div class="form-group">
          <label>Brand name</label>
          <input type="text" name="brand_name" value="<%= client.brand_name || '' %>">
        </div>
        <div class="form-group">
          <label>Settore</label>
          <select name="sector">
            <option value="">— Seleziona —</option>
            <% sectors.forEach(s => { %>
              <option value="<%= s.key %>" <%= client.sector === s.key ? 'selected' : '' %>><%= s.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Località</label>
          <input type="text" name="location" value="<%= client.location || '' %>">
        </div>
        <div class="form-group">
          <label>Sito web</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="text" name="website" value="<%= client.website || '' %>" style="flex:1">
            <button type="button" class="btn btn-secondary btn-sm" id="scan-website-btn" onclick="scanWebsite()" title="Analizza il sito e compila automaticamente i campi">Scansiona Sito</button>
          </div>
        </div>
        <div class="form-group">
          <label>Tagline</label>
          <input type="text" name="tagline" value="<%= client.tagline || '' %>">
        </div>
      </div>
      <div class="form-group">
        <label>Stato</label>
        <select name="status">
          <option value="active" <%= client.status === 'active' ? 'selected' : '' %>>Attivo</option>
          <option value="paused" <%= client.status === 'paused' ? 'selected' : '' %>>In pausa</option>
          <option value="archived" <%= client.status === 'archived' ? 'selected' : '' %>>Archiviato</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Salva Profilo</button>
    </form>
  </div>
</div>

<!-- Tab: Questionario -->
<div class="tab-content" id="tab-questionario">
  <div class="card">
    <div class="card-header">
      <h3>Questionari</h3>
      <div style="display:flex;gap:8px">
        <button class="btn btn-primary btn-sm" onclick="createQuestionnaire()">+ Nuovo Questionario</button>
        <label class="btn btn-secondary btn-sm" style="cursor:pointer;margin:0">
          Importa CSV
          <input type="file" accept=".csv" style="display:none" onchange="importCsv(this)">
        </label>
      </div>
    </div>
    <% if (questionnaires.length === 0) { %>
      <div class="empty-state"><p>Nessun questionario creato</p></div>
    <% } else { %>
      <table>
        <thead><tr><th>ID</th><th>Settore</th><th>Stato</th><th>Inviato</th><th>Link</th><th>Azioni</th></tr></thead>
        <tbody>
          <% questionnaires.forEach(q => { %>
          <tr>
            <td><code><%= q.id.substring(0, 8) %></code></td>
            <td><%= q.sector ? q.sector.replace(/_/g, ' ') : '—' %></td>
            <td><span class="badge badge-<%= q.status %>"><%= q.status %></span></td>
            <td><%= q.submitted_at || '—' %></td>
            <td><a href="/dashboard/q/<%= q.token %>" target="_blank" class="btn btn-sm btn-secondary">Apri</a></td>
            <td style="display:flex;gap:4px">
              <% if (q.status === 'submitted') { %>
                <button class="btn btn-sm btn-secondary" onclick="viewResponses('<%= q.id %>')">Risposte</button>
              <% } %>
              <button class="btn btn-sm" style="background:#ef4444;color:#fff" onclick="deleteQuestionnaire('<%= q.id %>')">Elimina</button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Tab: Piano Editoriale -->
<div class="tab-content" id="tab-piano">
  <div class="card">
    <div class="card-header">
      <h3>Piani Editoriali</h3>
      <button class="btn btn-primary btn-sm" onclick="generatePlan()" id="gen-plan-btn">Genera Piano con AI</button>
    </div>
    <% if (plans.length === 0) { %>
      <div class="empty-state"><p>Nessun piano editoriale. Genera il primo dal questionario compilato.</p></div>
    <% } else { %>
      <table>
        <thead><tr><th>Titolo</th><th>Stato</th><th>Creato</th><th>Azioni</th></tr></thead>
        <tbody>
          <% plans.forEach(p => { %>
          <tr>
            <td><%= p.title || 'Piano senza titolo' %></td>
            <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
            <td><%= p.created_at %></td>
            <td><a href="/dashboard/clients/<%= client.id %>/plan/<%= p.id %>" class="btn btn-sm btn-secondary">Apri</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Tab: Posts -->
<div class="tab-content" id="tab-posts">
  <div class="card">
    <div class="card-header"><h3>Tutti i Post</h3></div>
    <div id="posts-container"><div class="empty-state"><p>I post appariranno qui dopo aver generato un piano editoriale.</p></div></div>
  </div>
</div>

<!-- Tab: Impostazioni -->
<div class="tab-content" id="tab-impostazioni">
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3>Credenziali Social</h3></div>
    <form id="social-form">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="form-group">
          <label>Facebook Page ID</label>
          <input type="text" name="fb_page_id" value="<%= client.fb_page_id || '' %>">
        </div>
        <div class="form-group">
          <label>FB System User Token</label>
          <input type="password" name="fb_system_user_token" value="<%= client.fb_system_user_token || '' %>">
        </div>
        <div class="form-group">
          <label>Instagram User ID</label>
          <input type="text" name="ig_user_id" value="<%= client.ig_user_id || '' %>">
        </div>
        <div class="form-group">
          <label>IG Access Token</label>
          <input type="password" name="ig_access_token" value="<%= client.ig_access_token || '' %>">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Salva Credenziali</button>
    </form>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div class="card-header"><h3>AI Provider</h3></div>
    <form id="ai-form">
      <div class="form-group">
        <label>Provider AI</label>
        <select name="ai_provider" id="ai-provider-select">
          <option value="gemini" <%= client.ai_provider === 'gemini' || !client.ai_provider ? 'selected' : '' %>>Gemini 2.5 Flash (gratuito)</option>
          <option value="claude" <%= client.ai_provider === 'claude' ? 'selected' : '' %>>Claude Opus (premium)</option>
        </select>
      </div>
      <div class="form-group" id="gemini-key-group">
        <label>Gemini API Key</label>
        <input type="password" name="gemini_api_key" value="<%= client.gemini_api_key || '' %>">
      </div>
      <div class="form-group" id="anthropic-key-group">
        <label>Anthropic API Key</label>
        <input type="password" name="anthropic_api_key" value="<%= client.anthropic_api_key || '' %>">
      </div>
      <div class="form-group">
        <label>System Instruction (prompt personalizzato)</label>
        <textarea name="system_instruction" id="system-instruction-textarea" rows="8"><%= client.system_instruction || '' %></textarea>
        <button type="button" class="btn btn-secondary btn-sm" id="generate-si-btn" onclick="generateSystemInstruction()" style="margin-top:8px">Genera con AI</button>
      </div>
      <button type="submit" class="btn btn-primary">Salva AI Config</button>
    </form>
  </div>
  <div class="card">
    <div class="card-header"><h3>Logo e Tema</h3></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
      <!-- Logo Section -->
      <div>
        <p style="font-size:13px;color:var(--gray-500);margin-bottom:8px" id="logo-status-text">Logo: <%= client.logo_filename || 'non caricato' %></p>
        <div id="logo-preview-container" style="margin-bottom:12px;padding:12px;background:var(--gray-50);border-radius:8px;border:1px solid var(--gray-200);display:none">
          <img id="logo-preview-img" style="max-width:80px;max-height:80px;display:block">
        </div>
        <form id="logo-form" enctype="multipart/form-data">
          <input type="file" name="logo" accept=".svg,.jpg,.jpeg,.png">
          <button type="submit" class="btn btn-sm btn-secondary" style="margin-top:8px">Carica Logo</button>
        </form>
        <p style="font-size:11px;color:var(--gray-400);margin-top:4px">Formati: SVG, JPG, PNG (max 5MB)</p>
      </div>
      <!-- Theme Section -->
      <div>
        <p style="font-size:13px;color:var(--gray-500);margin-bottom:12px">Tema CSS: <%= client.theme_filename || 'non caricato' %></p>
        <!-- Brand colors pickers for theme generation -->
        <div style="margin-bottom:12px">
          <p style="font-size:12px;font-weight:600;color:var(--gray-600);margin-bottom:8px">Colori Brand</p>
          <div id="brand-colors-pickers" style="display:flex;flex-direction:column;gap:8px">
            <div class="color-picker-row" style="display:flex;align-items:center;gap:10px">
              <input type="color" id="brand-color-1" value="#6b9ef7" style="width:36px;height:36px;border:2px solid var(--gray-200);border-radius:8px;cursor:pointer;padding:2px">
              <div style="flex:1"><label style="font-size:11px;color:var(--gray-400);display:block">Colore primario</label><input type="text" id="brand-hex-1" value="#6b9ef7" style="font-size:13px;font-family:monospace;width:100%;padding:4px 8px;border:1px solid var(--gray-200);border-radius:4px" maxlength="7"></div>
            </div>
            <div class="color-picker-row" style="display:flex;align-items:center;gap:10px">
              <input type="color" id="brand-color-2" value="#1a1f2e" style="width:36px;height:36px;border:2px solid var(--gray-200);border-radius:8px;cursor:pointer;padding:2px">
              <div style="flex:1"><label style="font-size:11px;color:var(--gray-400);display:block">Colore secondario</label><input type="text" id="brand-hex-2" value="#1a1f2e" style="font-size:13px;font-family:monospace;width:100%;padding:4px 8px;border:1px solid var(--gray-200);border-radius:4px" maxlength="7"></div>
            </div>
            <div class="color-picker-row" style="display:flex;align-items:center;gap:10px">
              <input type="color" id="brand-color-3" value="#e8eaed" style="width:36px;height:36px;border:2px solid var(--gray-200);border-radius:8px;cursor:pointer;padding:2px">
              <div style="flex:1"><label style="font-size:11px;color:var(--gray-400);display:block">Colore terziario (opzionale)</label><input type="text" id="brand-hex-3" value="#e8eaed" style="font-size:13px;font-family:monospace;width:100%;padding:4px 8px;border:1px solid var(--gray-200);border-radius:4px" maxlength="7"></div>
            </div>
          </div>
          <button type="button" class="btn btn-sm btn-primary" id="generate-theme-btn" onclick="generateTheme()" style="margin-top:10px;width:100%">Genera Tema da colori</button>
        </div>
        <!-- Theme CSS variables editor (visible when theme exists) -->
        <div id="theme-colors-container" style="display:none;border-top:1px solid var(--gray-200);padding-top:12px;margin-bottom:12px">
          <p style="font-size:12px;font-weight:600;color:var(--gray-600);margin-bottom:8px">Variabili Tema CSS</p>
          <div id="theme-color-swatches" style="display:flex;flex-direction:column;gap:4px"></div>
          <button type="button" class="btn btn-sm btn-primary" id="save-colors-btn" onclick="saveThemeColors()" style="display:none;margin-top:10px;width:100%">Salva colori tema</button>
        </div>
        <form id="theme-form" enctype="multipart/form-data" style="border-top:1px solid var(--gray-200);padding-top:12px">
          <p style="font-size:11px;color:var(--gray-400);margin-bottom:6px">Oppure carica un file CSS manualmente</p>
          <input type="file" name="theme" accept=".css">
          <button type="submit" class="btn btn-sm btn-secondary" style="margin-top:8px">Carica Tema CSS</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Responses modal -->
<div class="modal-overlay" id="responses-modal">
  <div class="modal" style="max-width:700px">
    <h2>Risposte Questionario</h2>
    <pre id="responses-content" style="white-space:pre-wrap;font-size:13px;max-height:60vh;overflow-y:auto;background:var(--gray-50);padding:16px;border-radius:6px"></pre>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('responses-modal')">Chiudi</button>
    </div>
  </div>
</div>

<script>
  const CLIENT_ID = '<%= client.id %>';

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
    });
  });

  // Profile form
  document.getElementById('profile-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = {};
    new FormData(form).forEach((v, k) => { if (v) data[k] = v; });
    await apiFetch('/dashboard/api/clients/' + CLIENT_ID, { method: 'PUT', body: data });
    window.location.reload();
  });

  // Social form
  document.getElementById('social-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = {};
    new FormData(e.target).forEach((v, k) => { data[k] = v; });
    await apiFetch('/dashboard/api/clients/' + CLIENT_ID, { method: 'PUT', body: data });
    alert('Credenziali salvate');
  });

  // AI provider toggle
  function toggleAiKeyFields() {
    const provider = document.getElementById('ai-provider-select').value;
    document.getElementById('gemini-key-group').style.display = provider === 'gemini' ? '' : 'none';
    document.getElementById('anthropic-key-group').style.display = provider === 'claude' ? '' : 'none';
  }
  document.getElementById('ai-provider-select').addEventListener('change', toggleAiKeyFields);
  toggleAiKeyFields();

  // AI form
  document.getElementById('ai-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = {};
    new FormData(e.target).forEach((v, k) => { data[k] = v; });
    await apiFetch('/dashboard/api/clients/' + CLIENT_ID, { method: 'PUT', body: data });
    alert('Configurazione AI salvata');
  });

  // Logo preview loader (uses authenticated fetch → blob URL)
  async function loadLogoPreview() {
    const token = localStorage.getItem('dashboard_token');
    try {
      const res = await fetch('/dashboard/api/clients/' + CLIENT_ID + '/logo-preview', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (!res.ok) return;
      const blob = await res.blob();
      const img = document.getElementById('logo-preview-img');
      img.src = URL.createObjectURL(blob);
      document.getElementById('logo-preview-container').style.display = 'inline-block';
    } catch (err) { /* no logo, container stays hidden */ }
  }
  <% if (client.logo_filename) { %>loadLogoPreview();<% } %>

  // Logo upload with FileReader preview
  document.getElementById('logo-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fileInput = e.target.querySelector('input[type="file"]');
    const file = fileInput.files[0];
    if (!file) return;

    const formData = new FormData(e.target);
    const token = localStorage.getItem('dashboard_token');
    const res = await fetch('/dashboard/api/clients/' + CLIENT_ID + '/logo', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token },
      body: formData
    });
    if (res.ok) {
      // Show preview using FileReader (no endpoint dependency)
      const reader = new FileReader();
      reader.onload = function(ev) {
        const img = document.getElementById('logo-preview-img');
        img.src = ev.target.result;
        document.getElementById('logo-preview-container').style.display = 'inline-block';
      };
      reader.readAsDataURL(file);
      document.getElementById('logo-status-text').textContent = 'Logo: logo-' + CLIENT_ID + '.svg';
      alert('Logo caricato');
    }
  });

  // Theme upload
  document.getElementById('theme-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const token = localStorage.getItem('dashboard_token');
    const res = await fetch('/dashboard/api/clients/' + CLIENT_ID + '/theme', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token },
      body: formData
    });
    if (res.ok) {
      alert('Tema caricato');
      loadThemeColors();
    }
  });

  // --- Brand color pickers sync ---
  for (let i = 1; i <= 3; i++) {
    const picker = document.getElementById('brand-color-' + i);
    const hex = document.getElementById('brand-hex-' + i);
    picker.addEventListener('input', () => { hex.value = picker.value; });
    hex.addEventListener('input', () => {
      const v = hex.value.trim();
      if (/^#[0-9a-fA-F]{6}$/.test(v)) picker.value = v;
    });
  }

  function setBrandColors(colors) {
    for (let i = 0; i < 3; i++) {
      if (colors[i]) {
        const c = colors[i].length === 4 ? '#' + colors[i][1]+colors[i][1]+colors[i][2]+colors[i][2]+colors[i][3]+colors[i][3] : colors[i];
        document.getElementById('brand-color-' + (i + 1)).value = c;
        document.getElementById('brand-hex-' + (i + 1)).value = c;
      }
    }
  }

  function getBrandColors() {
    const colors = [];
    for (let i = 1; i <= 3; i++) {
      const v = document.getElementById('brand-hex-' + i).value.trim();
      if (/^#[0-9a-fA-F]{6}$/.test(v)) colors.push(v);
    }
    return colors;
  }

  // --- Theme CSS variables management ---

  const CSS_VAR_LABELS = {
    '--bg-deep': 'Sfondo profondo', '--bg-primary': 'Sfondo principale', '--bg-card': 'Sfondo card', '--bg-elevated': 'Sfondo elevato',
    '--accent': 'Accent', '--accent-light': 'Accent chiaro', '--accent-silver': 'Accent argento', '--accent-bright': 'Accent brillante',
    '--text-primary': 'Testo primario', '--text-light': 'Testo chiaro', '--text-medium': 'Testo medio', '--text-muted': 'Testo muto',
    '--border-cool': 'Bordo cool', '--border-elevated': 'Bordo elevato',
    '--glass-bg': 'Glass bg', '--overlay-top': 'Overlay top', '--overlay-bottom': 'Overlay bottom'
  };

  const CSS_VAR_GROUPS = {
    'Backgrounds': ['--bg-deep', '--bg-primary', '--bg-card', '--bg-elevated'],
    'Accents': ['--accent', '--accent-light', '--accent-silver', '--accent-bright'],
    'Testi': ['--text-primary', '--text-light', '--text-medium', '--text-muted'],
    'Bordi': ['--border-cool', '--border-elevated'],
    'Effetti': ['--glass-bg', '--overlay-top', '--overlay-bottom']
  };

  let currentThemeColors = {};

  function hexFromValue(val) {
    val = val.trim();
    if (val.startsWith('#')) return val.substring(0, 7);
    const rgbaMatch = val.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
    if (rgbaMatch) {
      return '#' + parseInt(rgbaMatch[1]).toString(16).padStart(2, '0') +
        parseInt(rgbaMatch[2]).toString(16).padStart(2, '0') +
        parseInt(rgbaMatch[3]).toString(16).padStart(2, '0');
    }
    return '#888888';
  }

  function renderThemeSwatches(colors) {
    const container = document.getElementById('theme-color-swatches');
    const wrapper = document.getElementById('theme-colors-container');
    container.innerHTML = '';

    if (!Object.keys(colors).length) { wrapper.style.display = 'none'; return; }
    wrapper.style.display = 'block';

    for (const [groupName, vars] of Object.entries(CSS_VAR_GROUPS)) {
      const header = document.createElement('div');
      header.style.cssText = 'font-size:10px;color:var(--gray-400);text-transform:uppercase;letter-spacing:0.5px;margin-top:8px;margin-bottom:2px';
      header.textContent = groupName;
      container.appendChild(header);

      vars.forEach(varName => {
        if (!colors[varName]) return;
        const hex = hexFromValue(colors[varName]);
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:3px 0';
        row.innerHTML =
          '<input type="color" value="' + hex + '" data-var="' + varName + '" style="width:30px;height:30px;border:2px solid var(--gray-200);border-radius:6px;cursor:pointer;padding:1px">' +
          '<div style="flex:1"><label style="font-size:11px;color:var(--gray-400);display:block">' + (CSS_VAR_LABELS[varName] || varName) + '</label>' +
          '<input type="text" value="' + colors[varName] + '" data-var="' + varName + '" style="font-size:12px;font-family:monospace;width:100%;padding:2px 6px;border:1px solid var(--gray-200);border-radius:4px" maxlength="30"></div>';

        const colorInput = row.querySelector('input[type="color"]');
        const textInput = row.querySelector('input[type="text"]');

        colorInput.addEventListener('input', function() {
          textInput.value = this.value;
          currentThemeColors[varName] = this.value;
          document.getElementById('save-colors-btn').style.display = '';
        });
        textInput.addEventListener('input', function() {
          const v = this.value.trim();
          const h = hexFromValue(v);
          colorInput.value = h;
          currentThemeColors[varName] = v;
          document.getElementById('save-colors-btn').style.display = '';
        });
        container.appendChild(row);
      });
    }
  }

  async function loadThemeColors() {
    try {
      const res = await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/theme-colors');
      if (res.exists && res.colors) {
        currentThemeColors = res.colors;
        renderThemeSwatches(res.colors);
      }
    } catch (err) {
      console.error('Error loading theme colors:', err);
    }
  }

  async function saveThemeColors() {
    const btn = document.getElementById('save-colors-btn');
    btn.disabled = true;
    btn.textContent = 'Salvataggio...';
    try {
      await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/theme-colors', {
        method: 'PUT',
        body: { colors: currentThemeColors }
      });
      btn.style.display = 'none';
      alert('Colori del tema aggiornati');
    } catch (err) {
      alert('Errore: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Salva colori tema';
    }
  }

  async function generateTheme() {
    const colors = getBrandColors();
    if (colors.length < 2) {
      alert('Seleziona almeno 2 colori brand con i picker');
      return;
    }

    const btn = document.getElementById('generate-theme-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="loading"></span> Generazione tema...';

    try {
      const res = await apiFetch('/dashboard/api/clients/' + CLIENT_ID + '/generate-theme', {
        method: 'POST',
        body: { colors }
      });
      if (res.error) { alert('Errore: ' + res.error); return; }
      if (res.colors) {
        currentThemeColors = res.colors;
        renderThemeSwatches(res.colors);
      }
      alert('Tema generato e salvato');
    } catch (err) {
      alert('Errore: ' + (err.message || 'Generazione fallita'));
    } finally {
      btn.disabled = false;
      btn.textContent = 'Genera Tema da colori';
    }
  }

  // Load theme colors on page load
  loadThemeColors();

  // Import CSV from Google Forms
  async function importCsv(input) {
    const file = input.files[0];
    if (!file) return;
    input.value = '';

    const text = await file.text();
    const lines = [];
    let current = '';
    let inQuotes = false;

    // Parse CSV handling quoted fields with commas and newlines
    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      if (ch === '"') {
        if (inQuotes && text[i + 1] === '"') {
          current += '"';
          i++;
        } else {
          inQuotes = !inQuotes;
        }
      } else if (ch === ',' && !inQuotes) {
        if (!lines.length) lines.push([]);
        lines[lines.length - 1].push(current);
        current = '';
      } else if ((ch === '\n' || (ch === '\r' && text[i + 1] === '\n')) && !inQuotes) {
        if (!lines.length) lines.push([]);
        lines[lines.length - 1].push(current);
        current = '';
        lines.push([]);
        if (ch === '\r') i++;
      } else {
        current += ch;
      }
    }
    if (current || (lines.length && lines[lines.length - 1])) {
      if (!lines.length) lines.push([]);
      lines[lines.length - 1].push(current);
    }

    if (lines.length < 2) {
      alert('Il CSV deve avere almeno 2 righe (header + risposte)');
      return;
    }

    const headers = lines[0];
    const values = lines[1];

    // Build responses object: { question: answer }
    const responses = {};
    headers.forEach((h, i) => {
      const question = h.trim();
      const answer = (values[i] || '').trim();
      if (question && question !== 'Informazioni cronologiche' && answer) {
        responses[question] = answer;
      }
    });

    if (Object.keys(responses).length === 0) {
      alert('Nessuna risposta trovata nel CSV');
      return;
    }

    // Create questionnaire then import responses
    const q = await apiFetch('/dashboard/api/questionnaires', {
      method: 'POST',
      body: { client_id: CLIENT_ID }
    });
    if (q.error) { alert(q.error); return; }

    const res = await apiFetch('/dashboard/api/questionnaires/' + q.id + '/import-csv', {
      method: 'POST',
      body: { responses }
    });
    if (res.error) { alert(res.error); return; }

    alert('CSV importato: ' + Object.keys(responses).length + ' risposte caricate');
    window.location.reload();
  }

  // Create questionnaire
  async function deleteQuestionnaire(id) {
    if (!confirm('Eliminare questo questionario?')) return;
    const res = await apiFetch('/dashboard/api/questionnaires/' + id, { method: 'DELETE' });
    if (res.error) { alert(res.error); return; }
    window.location.reload();
  }

  async function createQuestionnaire() {
    const res = await apiFetch('/dashboard/api/questionnaires', {
      method: 'POST',
      body: { client_id: CLIENT_ID }
    });
    if (res.error) { alert(res.error); return; }
    window.location.reload();
  }

  // View responses
  async function viewResponses(id) {
    const res = await apiFetch('/dashboard/api/questionnaires/' + id);
    document.getElementById('responses-content').textContent = JSON.stringify(res.responses || {}, null, 2);
    openModal('responses-modal');
