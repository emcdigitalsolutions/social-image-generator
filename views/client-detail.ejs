  // Generate plan
  async function generatePlan() {
    const btn = document.getElementById('gen-plan-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="loading"></span> Generazione in corso...';
    try {
      const res = await apiFetch('/dashboard/api/plans/generate', {
        method: 'POST',
        body: { client_id: CLIENT_ID }
      });
      if (res.error) { alert(res.error); return; }
